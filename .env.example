# ============================================================================
# PCI-DSS Compliance Tracker — Environment Variables
# Copy this file to .env and fill in the values
# ============================================================================

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pci_dss_db
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Redis (optional — app starts without it)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Spring Boot
SERVER_PORT=8080

# JWT (must be ≥ 32 characters for HMAC-SHA256)
JWT_SECRET=pci-dss-tracker-dev-secret-key-must-be-at-least-256-bits-long-for-hmac-sha
JWT_EXPIRATION=86400000
JWT_EXPIRY_SECONDS=3600
JWT_REFRESH_EXPIRY_SECONDS=604800

# Mail (SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# AI Service
AI_SERVICE_URL=http://localhost:5000
GROQ_API_KEY=

# Scheduler
SCHEDULER_ADMIN_EMAIL=admin@pcidss-demo.com
