# =============================================================================
# PCI-DSS Compliance Tracker — Environment Variables
# Copy this file to .env and fill in ALL placeholder values before running
# docker-compose up --build
#
#   cp .env.example .env
#
# NEVER commit the .env file to version control.
# =============================================================================


# -----------------------------------------------------------------------------
# Database (PostgreSQL 15)
# -----------------------------------------------------------------------------
# Name of the database that will be created inside the postgres container
POSTGRES_DB=pci_dss_db

# Superuser credentials for the database
POSTGRES_USER=pci_user
POSTGRES_PASSWORD=change_me_db_password


# -----------------------------------------------------------------------------
# Redis 7
# -----------------------------------------------------------------------------
# Password for the Redis instance (requirepass)
REDIS_PASSWORD=change_me_redis_password


# -----------------------------------------------------------------------------
# Backend (Spring Boot)
# -----------------------------------------------------------------------------
# Host port that maps to the backend container's port 8080
BACKEND_PORT=8080

# URL of the AI service reachable from inside the Docker network
AI_SERVICE_URL=http://ai-service:5000

# Email address that receives scheduled compliance deadline alerts
SCHEDULER_ADMIN_EMAIL=admin@example.com


# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------
# Long random string (≥ 256 bits) used to sign JWT tokens
JWT_SECRET=change_me_super_long_jwt_secret_at_least_32_chars

# Access token lifetime in milliseconds (default: 1 hour)
JWT_EXPIRY_MS=3600000

# Refresh token lifetime in milliseconds (default: 7 days)
REFRESH_TOKEN_EXPIRY_MS=604800000


# -----------------------------------------------------------------------------
# Mail (SMTP)
# -----------------------------------------------------------------------------
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your_app_password
# "From" address shown in outgoing emails
MAIL_FROM=noreply@example.com


# -----------------------------------------------------------------------------
# AI Service (Flask / Groq)
# -----------------------------------------------------------------------------
# Host port that maps to the ai-service container's port 5000
AI_PORT=5000

# Groq cloud API key
GROQ_API_KEY=your_groq_api_key_here

# Path (inside the container) where ChromaDB persists its vector store
CHROMA_PATH=/app/chroma_store

# Name of the Groq LLM model to use
MODEL_NAME=llama3-8b-8192
