# ============================================================================
# PCI-DSS Compliance Tracker — Environment Variables
# Copy this file to .env and fill in the values
# ============================================================================

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pci_dss_db
DB_USERNAME=
DB_PASSWORD=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Spring Boot
SERVER_PORT=8080

# JWT
JWT_SECRET=
JWT_EXPIRATION=86400000

# Mail (SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# AI Service
AI_SERVICE_URL=http://localhost:5000
GROQ_API_KEY=
